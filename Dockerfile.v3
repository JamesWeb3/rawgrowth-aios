# syntax=docker/dockerfile:1.7

# ─────────────────────────────────────────────────────────────
# Rawgrowth AIOS v3 — per-client VPS image with Supabase cloud
# Delta from ./Dockerfile (self-hosted):
#   - DEPLOY_MODE=v3 default
#   - whisper.cpp binary + base.en model bundled for voice fallback
#   - (no local postgres/postgrest deps; Supabase is remote)
# ─────────────────────────────────────────────────────────────

FROM node:24-bookworm-slim AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci

FROM node:24-bookworm-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ── whisper.cpp build stage ───────────────────────────────────
# Bundles a static whisper-cli binary + the base.en GGML model as
# the Path-B voice transcription fallback. Used only when
# ANTHROPIC_API_KEY is missing / Path-A call fails. base.en is ~150MB
# and hits good-enough accuracy for short Telegram voice notes in
# English. Swap WHISPER_MODEL to small.en if a client needs more.
FROM debian:bookworm-slim AS whisper
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential cmake git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /src
RUN git clone --depth 1 https://github.com/ggerganov/whisper.cpp.git . && \
    cmake -B build -DCMAKE_BUILD_TYPE=Release -DWHISPER_BUILD_TESTS=OFF && \
    cmake --build build -j --config Release && \
    mkdir -p /out/bin /out/model && \
    cp build/bin/whisper-cli /out/bin/whisper-cli && \
    curl -fsSL -o /out/model/ggml-base.en.bin \
      https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin

FROM node:24-bookworm-slim AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    DEPLOY_MODE=v3 \
    WHISPER_BIN=/usr/local/bin/whisper-cli \
    WHISPER_MODEL=/usr/local/share/whisper/ggml-base.en.bin

RUN apt-get update && \
    apt-get install -y --no-install-recommends libstdc++6 libgcc-s1 && \
    rm -rf /var/lib/apt/lists/*

# Drop root
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 --ingroup nodejs nextjs

# Next.js standalone
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# Migrations + entrypoint
COPY --from=builder --chown=nextjs:nodejs /app/scripts ./scripts
COPY --from=builder --chown=nextjs:nodejs /app/supabase/migrations ./supabase/migrations
COPY --from=builder --chown=nextjs:nodejs /app/docker/entrypoint.sh /usr/local/bin/entrypoint.sh

# Whisper binary + model
COPY --from=whisper /out/bin/whisper-cli /usr/local/bin/whisper-cli
COPY --from=whisper /out/model/ggml-base.en.bin /usr/local/share/whisper/ggml-base.en.bin

# fastembed + onnxruntime-node native binaries.
# next.config.ts marks fastembed/onnxruntime-node/@anush008/tokenizers/tar/
# @huggingface/hub/progress as serverExternalPackages so Next.js standalone
# loads them from node_modules at runtime instead of bundling. nft (the
# tracer behind `output: standalone`) reliably copies the .js + .node
# files, but the companion libonnxruntime.so.1 / libonnxruntime_providers_*.so
# siblings of onnxruntime_binding.node frequently get dropped, leaving
# the .node binding to dlopen against a missing libonnxruntime.so.1 at
# runtime (`cannot open shared object file`). The embedder catches the
# throw and falls back to stub embeddings, so RAG silently degrades to
# noise. Re-copy the full package trees from the builder so every .so
# travels with its .node binding. ONNX runpath is $ORIGIN/ so libs are
# found beside the binding; no LD_LIBRARY_PATH needed. Adds ~40MB.
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/onnxruntime-node ./node_modules/onnxruntime-node
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/onnxruntime-common ./node_modules/onnxruntime-common
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/fastembed ./node_modules/fastembed
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/@anush008 ./node_modules/@anush008
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/@huggingface ./node_modules/@huggingface
COPY --from=builder --chown=nextjs:nodejs /app/node_modules/progress ./node_modules/progress
# tar lives only under fastembed/node_modules/tar (nested install via
# package-lock); a top-level COPY of node_modules/tar would break the
# build because npm hoisting put it deeper. fastembed resolves via
# node's nearest-node_modules walk, so the nested copy is enough.

# Runtime Node deps (pg/jwt/bcrypt pulled with full transitives)
RUN npm install --omit=dev --no-save --no-package-lock \
      pg@^8 jsonwebtoken@^9 bcryptjs@^3

RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/whisper-cli

USER nextjs

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["node", "server.js"]
